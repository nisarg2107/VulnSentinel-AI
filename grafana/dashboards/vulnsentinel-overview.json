          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  CASE sr.status\n    WHEN 'affected' THEN 'open'\n    WHEN 'not_affected' THEN 'suppressed'\n    ELSE sr.status\n  END AS status,\n  COUNT(*) AS total\nFROM scan_results sr\nJOIN scans s ON s.id = sr.scan_id\nWHERE s.status = 'completed'\nGROUP BY 1\nORDER BY total DESC;",
          "refId": "A"
        }
      ],
      "title": "VEX Suppression Breakdown",
